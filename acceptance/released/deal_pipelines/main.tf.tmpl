terraform {
  required_version = ">= 1.8"

  required_providers {
    hubspot = {
      source  = "__PROVIDER_SOURCE__"
      version = "__PROVIDER_VERSION__"
    }
  }
}

variable "hubspot_access_token" {
  type        = string
  description = "Access token for the isolated deal-pipeline acceptance account."
  sensitive   = true
  nullable    = false
}

variable "acceptance_prefix" {
  type        = string
  description = "Unique prefix owned by this released-provider verification run."
  nullable    = false

  validation {
    condition     = can(regex("^tf_acc_[A-Za-z0-9_]+_$", var.acceptance_prefix))
    error_message = "acceptance_prefix must start with tf_acc_ and end with an underscore."
  }
}

variable "open_stage_key" {
  type    = string
  default = "open"
}

variable "closed_stage_key" {
  type    = string
  default = "closed"
}

provider "hubspot" {
  access_token = var.hubspot_access_token
}

resource "hubspot_pipeline" "released" {
  object_type   = "deals"
  label         = "${var.acceptance_prefix}released_deal_pipeline"
  display_order = 100

  stages = {
    (var.open_stage_key) = {
      label         = "Released provider open stage"
      display_order = 10
      metadata      = { probability = "0.1" }
    }
    (var.closed_stage_key) = {
      label         = "Released provider closed stage"
      display_order = 20
      metadata      = { probability = "1.0" }
    }
  }
}
