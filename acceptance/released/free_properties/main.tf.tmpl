terraform {
  required_version = ">= 1.8"

  required_providers {
    hubspot = {
      source  = "__PROVIDER_SOURCE__"
      version = "__PROVIDER_VERSION__"
    }
  }
}

variable "hubspot_access_token" {
  type        = string
  description = "Access token for the isolated Free acceptance account."
  sensitive   = true
  nullable    = false
}

variable "acceptance_prefix" {
  type        = string
  description = "Unique prefix owned by this released-provider verification run."
  nullable    = false

  validation {
    condition     = can(regex("^tf_acc_[A-Za-z0-9_]+_$", var.acceptance_prefix))
    error_message = "acceptance_prefix must start with tf_acc_ and end with an underscore."
  }
}

provider "hubspot" {
  access_token = var.hubspot_access_token
}

resource "hubspot_property_group" "released" {
  object_type   = "contacts"
  name          = "${var.acceptance_prefix}released_group"
  label         = "Released provider property definitions"
  display_order = 100
}

resource "hubspot_property" "scalar" {
  object_type   = "contacts"
  name          = "${var.acceptance_prefix}released_scalar"
  label         = "Released provider scalar property"
  group_name    = hubspot_property_group.released.name
  type          = "string"
  field_type    = "text"
  display_order = 110
}

resource "hubspot_property" "enumeration" {
  object_type   = "contacts"
  name          = "${var.acceptance_prefix}released_enumeration"
  label         = "Released provider enumeration property"
  group_name    = hubspot_property_group.released.name
  type          = "enumeration"
  field_type    = "select"
  display_order = 120

  options = {
    alpha = { label = "Alpha", display_order = 130 }
    beta  = { label = "Beta", display_order = 140 }
  }
}

data "hubspot_property_definition" "scalar" {
  object_type = "contacts"
  name        = hubspot_property.scalar.name
}

data "hubspot_property_definitions" "released" {
  object_type = "contacts"
  depends_on  = [hubspot_property.enumeration]
}
